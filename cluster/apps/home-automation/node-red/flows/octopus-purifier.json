    {
      "id": "oct_pick",
      "type": "function",
      "z": "08c9061c9f25ce0d",
      "name": "pick 6 cheapest slots",
      "func": "const rates = (msg.data && msg.data.attributes && msg.data.attributes.rates) || [];\nif (!rates.length) { node.warn('Octopus: no rates'); node.status({fill:'red',shape:'ring',text:'no rates'}); return null; }\nconst N = 6;\nconst cheapest = [...rates].sort((a,b)=>a.value_inc_vat-b.value_inc_vat).slice(0,N)\n  .map(r=>({from:r.start, to:r.end, price:r.value_inc_vat}));\nflow.set('cheapestSlots', cheapest);\nconst ordered=[...cheapest].sort((a,b)=>Date.parse(a.from)-Date.parse(b.from));\nconst fmt=s=>new Date(s.from).toLocaleTimeString('en-GB',{hour:'2-digit',minute:'2-digit'});\nnode.status({fill:'green',shape:'dot',text:`${N} slots: ${ordered.map(fmt).join(',')}`});\nnode.warn('Octopus cheapest '+N+': '+ordered.map(s=>fmt(s)+'='+(s.price*100).toFixed(2)+'p').join(', '));\nreturn null;",
      "outputs": 1,
      "timeout": 0,
      "noerr": 0,
      "initialize": "",
      "finalize": "",
      "libs": [],
      "x": 980,
      "y": 80,
      "wires": [
        []
      ]
    },
    {
      "id": "oct_inj_tick",
      "type": "inject",
      "z": "08c9061c9f25ce0d",
      "name": "every 1 min",
      "props": [
        {
          "p": "payload"
        }
      ],
      "repeat": "60",
